# PHP CLI окружение для PHPUnit + Orchestra Testbench.
# Только для тестов пакета (docker-compose.test.yml), к проектам-форкам отношения не имеет.

FROM php:8.4-cli-alpine

RUN apk add --no-cache --virtual .build-deps \
        $PHPIZE_DEPS \
        libzip-dev \
        icu-dev \
        oniguruma-dev \
        sqlite-dev \
    && apk add --no-cache \
        git \
        unzip \
        libzip \
        icu \
        oniguruma \
        sqlite-libs \
    && docker-php-ext-install -j"$(nproc)" \
        pdo_sqlite \
        bcmath \
        zip \
        intl \
        mbstring \
    && apk del .build-deps

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /app
