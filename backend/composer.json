{
    "name": "cgehuzi/core-backend",
    "description": "Архитектурное ядро (backend) для проектов на base projects-skeleton: Laravel-сервисы, Filament-ресурсы и render-API для headless-фронтенда.",
    "type": "library",
    "version": "0.0.1",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "filament/filament": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Cgehuzi\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cgehuzi\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cgehuzi\\Core\\CoreServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
