{
  "name": "@cgehuzi/core-frontend",
  "version": "0.0.1",
  "description": "Архитектурное ядро (frontend): TypeScript-типы и клиент для render-API Laravel из Next.js.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./api-client": {
      "types": "./src/api-client.ts",
      "default": "./src/api-client.ts"
    }
  },
  "files": [
    "src",
    "tsconfig.json",
    "README.md"
  ],
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "engines": {
    "node": ">=20"
  }
}
